with parsed_value as (
  select concept_code, concept_name, split_part(concept_code, '@', 1) as sch, split_part(concept_code, '@', 2) as item, split_part(concept_code, '@', 3) as value from concept_stage where regexp_count(concept_code, '@')=2 and concept_class_id='NAACCR Value' and invalid_reason is null
union
  select concept_code, concept_name, '' as sch, split_part(concept_code, '@', 1) as item, split_part(concept_code, '@', 2) as value from concept_stage where regexp_count(concept_code, '@')=1 and concept_class_id='NAACCR Value' and invalid_reason is null
),
parsed_item as (
  select concept_code, concept_name, split_part(concept_code, '@', 1) as sch, split_part(concept_code, '@', 2) as item from concept_stage where regexp_count(concept_code, '@')=1 and concept_class_id='NAACCR Variable' and invalid_reason is null
union
  select concept_code, concept_name, '' as sch, concept_code as item from concept_stage where position('@' in concept_code)=0 and concept_class_id='NAACCR Variable' and invalid_reason is null
)
select p_i.concept_code, p_i.concept_name, relationship_id, concept_code_2, c2.concept_name
-- select p_i.concept_code as variable_code, p_i.concept_name as variable_name, p_v.concept_code as value_code, p_v.concept_name as value_name, sch, item, value
from parsed_value p_v
full join parsed_item p_i using(sch, item)
left join concept_relationship_stage on p_i.concept_code=concept_code_1
left join concept_stage c2 on c2.concept_code=concept_code_2
where
-- p_i is null -- variable doesn't exist
-- p_v is null -- value doesn't exist
-- relationship doesn't exist
p_i is not null and p_v is not null and not exists (select 1 from concept_relationship_stage where concept_code_1=p_i.concept_code and concept_code_2=p_v.concept_code and relationship_id='Has Answer')
--  p_i is null or p_v is null) and exists (select 1 from concept_relationship_stage where (concept_code_1=p_i.concept_code or concept_code_2=p_v.concept_code) and relationship_id='Has Answer')
;

